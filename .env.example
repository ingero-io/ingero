# TensorDock API token — get yours at: https://dashboard.tensordock.com/developers
TENSORDOCK_API_TOKEN=your-token-here

# Lambda Labs API key — get yours at: https://cloud.lambdalabs.com/api-keys
# Auth: HTTP Basic (-u "$TOKEN:"), NOT Bearer.
LAMBDALABS_API_TOKEN=your-key-here

# Azure subscription ID — get yours at: https://portal.azure.com/#view/Microsoft_Azure_Billing/SubscriptionsBlade
# Auth: Azure CLI (az login), not API tokens. Subscription auto-detected if omitted.
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
